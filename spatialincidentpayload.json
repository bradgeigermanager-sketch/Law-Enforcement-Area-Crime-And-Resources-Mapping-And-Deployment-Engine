{
  "$schema": "https://json-schema.org",
  "title": "SpatialIncidentPayload",
  "type": "object",
  "properties": {
    "incident_id": { "type": "integer" },
    "statute_code": { "type": "string" },
    "category": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "location": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Point"] },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "number" }
        }
      },
      "required": ["type", "coordinates"]
    }
  },
  "required": ["incident_id", "statute_code", "category", "timestamp", "location"]
}

